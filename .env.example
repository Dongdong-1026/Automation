# ============================================================
# .env.example - GitHub Secrets 配置参考
# ============================================================
# 在 GitHub Repository Settings > Secrets and variables > Actions 中添加以下 secrets：

# AllTick API 密钥（必需）
# ALLTICK_API_KEY=your_alltick_api_key_here
# ALLTICK_API_URL=https://api.alltick.co/v1/ohlcv
# ALLTICK_CALENDAR_API_URL=https://api.alltick.co/v1/calendar

# 可选：默认 Ticker（可在 GitHub Variables 中设置 DEFAULT_TICKER）
# DEFAULT_TICKER=^HSI
